{
  "mcpServers": {
    "rocannon": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/path/to/rocannon",
        "rocannon",
        "mcp",
        "serve",
        "--profile",
        "/path/to/rocannon/examples/quickstart/profile.yml"
      ],
      "alwaysAllow": [],
      "disabled": false
    }
  }
}
